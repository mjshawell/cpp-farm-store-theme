<section class="loyalty-rewards">
  <div class="loyalty-rewards__left">
    <p class="loyalty-eyebrow">Loyalty Program</p>

    <h2>Earn rewards every time you shop.</h2>

    <p>
      Members earn points for every purchase. Redeem your points
      for discounts on future Farm Store orders.
    </p>

    <a href="#" class="loyalty-btn" onclick="
  event.preventDefault();
  var frame = document.querySelector('[id*=smile-lite-launcher-frame]');
  if(frame) {
    try {
      var btn = frame.contentDocument.querySelector('button');
      if(btn) { btn.click(); return; }
    } catch(e) {}
  }
  var btns = document.querySelectorAll('button');
  for(var i = 0; i < btns.length; i++) {
    if(btns[i].getAttribute('aria-label') && btns[i].getAttribute('aria-label').indexOf('Smile') > -1) {
      btns[i].click();
      return;
    }
  }
">
  Join Rewards Program
</a>
  </div>

  <div class="loyalty-rewards__right">

    <div class="reward-card">
      <h3>5 Points</h3>
      <p>For every $1 spent</p>
    </div>

    <div class="reward-card">
      <h3>100 Points</h3>
      <p>$1 Order Discount</p>
    </div>

    <div class="reward-card">
      <h3>Place an Order</h3>
      <p>Start earning points with your first purchase</p>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Loyalty Rewards",
  "settings": [],
  "presets": [
    {
      "name": "Loyalty Rewards"
    }
  ]
}
{% endschema %}