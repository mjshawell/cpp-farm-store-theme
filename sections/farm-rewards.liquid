<style>
.farm-rewards-page {
  background: #f7f2ea;
  color: #4e3a32;
}

.farm-rewards-page__hero {
  background: #203c26;
  color: #ffffff;
  padding: 100px 8%;
  text-align: center;
}

.farm-rewards-page__eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-weight: 900;
  color: #bf9568;
  margin-bottom: 16px;
  font-size: 0.9rem;
}

.farm-rewards-page__hero h1 {
  color: #ffffff;
  font-size: clamp(2.8rem, 6vw, 5.5rem);
  line-height: 1;
  margin: 0 0 22px;
}

.farm-rewards-page__hero p {
  font-size: 1.15rem;
  line-height: 1.7;
  max-width: 680px;
  margin: 0 auto 34px;
  color: #f7f2ea;
}

.farm-rewards-page__steps {
  padding: 100px 8%;
  text-align: center;
}

.farm-rewards-page__steps h2,
.farm-rewards-page__table-section h2,
.farm-rewards-page__cta h2 {
  font-size: clamp(2.4rem, 5vw, 4.5rem);
  line-height: 1;
  color: #203c26;
  margin: 0 0 48px;
}

.farm-rewards-page__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  max-width: 1200px;
  margin: 0 auto;
}

.farm-rewards-page__card {
  background: #ffffff;
  border-radius: 28px;
  padding: 40px 32px;
  box-shadow: 0 18px 45px rgba(78, 58, 50, 0.10);
  text-align: left;
}

.farm-rewards-page__icon {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: #203c26;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  font-weight: 900;
  margin-bottom: 22px;
}

.farm-rewards-page__card h3 {
  color: #203c26;
  font-size: 1.4rem;
  margin: 0 0 12px;
}

.farm-rewards-page__card p {
  color: #4e3a32;
  line-height: 1.65;
  margin: 0 0 18px;
}

.farm-rewards-page__table-section {
  padding: 100px 8%;
  background: #ffffff;
  text-align: center;
}

.farm-rewards-page__table-wrap {
  max-width: 800px;
  margin: 0 auto;
  overflow-x: auto;
}

.farm-rewards-page__table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
}

.farm-rewards-page__table th {
  background: #203c26;
  color: #ffffff;
  padding: 16px 22px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: 0.85rem;
}

.farm-rewards-page__table td {
  padding: 16px 22px;
  border-bottom: 1px solid #e5d8c8;
  color: #4e3a32;
}

.farm-rewards-page__table tr:last-child td {
  border-bottom: none;
}

.farm-rewards-page__table tr:nth-child(even) td {
  background: #f7f2ea;
}

.farm-rewards-page__cta {
  padding: 100px 8%;
  text-align: center;
  background: #4e3a32;
  color: #ffffff;
}

.farm-rewards-page__cta h2 {
  color: #ffffff;
}

.farm-rewards-page__cta p {
  font-size: 1.15rem;
  line-height: 1.7;
  max-width: 680px;
  margin: 0 auto 20px;
  color: #f7f2ea;
}

@media (max-width: 900px) {
  .farm-rewards-page__grid {
    grid-template-columns: 1fr;
  }
}
</style>

<section class="farm-rewards-page">

  <div class="farm-rewards-page__hero">
    <p class="farm-rewards-page__eyebrow">Farm Rewards Program</p>
    <h1>Earn rewards every time you shop.</h1>
    <p>Join the CPP Farm Store loyalty program and earn points on every purchase. Redeem your points for discounts on future orders.</p>
  </div>

  <div class="farm-rewards-page__steps">
    <p class="farm-rewards-page__eyebrow">How It Works</p>
    <h2>Three simple steps</h2>

    <div class="farm-rewards-page__grid">

      <div class="farm-rewards-page__card">
        <div class="farm-rewards-page__icon">1</div>
        <h3>Create an Account</h3>
        <p>Sign up for a free CPP Farm Store account using the account icon in the top right corner of any page to start tracking your points and rewards automatically.</p>
      </div>

      <div class="farm-rewards-page__card">
        <div class="farm-rewards-page__icon">2</div>
        <h3>Shop & Earn Points</h3>
        <p>Earn <strong>5 points for every $1 spent</strong> on any order. Points are added automatically after each purchase.</p>
      </div>

      <div class="farm-rewards-page__card">
        <div class="farm-rewards-page__icon">3</div>
        <h3>Redeem for Discounts</h3>
        <p>Every <strong>100 points = $1 off</strong> your order. Redeem your points at checkout for instant savings.</p>
      </div>

    </div>
  </div>

  <div class="farm-rewards-page__table-section">
    <p class="farm-rewards-page__eyebrow">Rewards Breakdown</p>
    <h2>What you can earn</h2>

    <div class="farm-rewards-page__table-wrap">
      <table class="farm-rewards-page__table">
        <thead>
          <tr>
            <th>Action</th>
            <th>Points Earned</th>
            <th>Dollar Value</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Place an order</td>
            <td>5 pts per $1 spent</td>
            <td>Varies</td>
          </tr>
          <tr>
            <td>100 points</td>
            <td>—</td>
            <td>$1 order discount</td>
          </tr>
          <tr>
            <td>500 points</td>
            <td>—</td>
            <td>$5 order discount</td>
          </tr>
          <tr>
            <td>1,000 points</td>
            <td>—</td>
            <td>$10 order discount</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="farm-rewards-page__cta">
    <p class="farm-rewards-page__eyebrow">Get Started</p>
    <h2>Ready to start earning?</h2>
    <p>Click the <strong>account icon</strong> in the top right corner of any page to sign in or create an account. Once logged in, your points will be tracked automatically with every purchase.</p>
    <p>Already a member? Click the <strong>Rewards</strong> button in the bottom right corner to check your points balance.</p>
  </div>

</section>

{% schema %}
{
  "name": "Farm Rewards Page",
  "settings": [],
  "presets": [
    {
      "name": "Farm Rewards Page"
    }
  ]
}
{% endschema %}
