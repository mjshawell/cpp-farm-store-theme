<section class="farm-cart">
  <div class="farm-cart__header">
    <p class="farm-cart__eyebrow">Review Your Order</p>
    <h1>Shopping Cart</h1>
    <p>
      Review your Farm Store gift order details before checkout. Pickup and shipping
      details will be confirmed by the Farm Store team.
    </p>
  </div>

  {% if cart.item_count > 0 %}

    <form action="{{ routes.cart_url }}" method="post" class="farm-cart__form">

      <div class="farm-cart__layout">

        <div class="farm-cart__items">

          {% for item in cart.items %}

            <article class="farm-cart__item">

              <div class="farm-cart__image">
                {% if item.image %}
                  <img
                    src="{{ item.image | image_url: width: 500 }}"
                    alt="{{ item.image.alt | default: item.product.title | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="farm-cart__placeholder">
                    🎁
                  </div>
                {% endif %}
              </div>

              <div class="farm-cart__details">

                <div class="farm-cart__item-heading">
                  <div>
                    <p class="farm-cart__product-type">
                      {{ item.product.type | default: 'Farm Store Gift' }}
                    </p>

                    <h2>
                      <a href="{{ item.url }}">
                        {{ item.product.title }}
                      </a>
                    </h2>

                    {% unless item.variant.title == 'Default Title' %}
                      <p class="farm-cart__variant">
                        {{ item.variant.title }}
                      </p>
                    {% endunless %}
                  </div>

                  <p class="farm-cart__line-price">
                    {{ item.final_line_price | money }}
                  </p>
                </div>

                {% if item.properties.size > 0 %}
                  <div class="farm-cart__properties">
                    <h3>Gift Order Details</h3>

                    <dl>
                      {% for property in item.properties %}
                        {% assign property_first_character = property.first | slice: 0 %}

                        {% unless property.last == blank or property_first_character == '_' %}
                          <div class="farm-cart__property-row">
                            <dt>{{ property.first }}</dt>

                            <dd>
                              {% if property.last contains '/uploads/' %}
                                <a href="{{ property.last }}" target="_blank">
                                  View uploaded file
                                </a>
                              {% else %}
                                {{ property.last }}
                              {% endif %}
                            </dd>
                          </div>
                        {% endunless %}
                      {% endfor %}
                    </dl>
                  </div>
                {% endif %}

                <div class="farm-cart__controls">
                  <label for="updates_{{ item.key }}">
                    Quantity
                  </label>

                  <input
                    id="updates_{{ item.key }}"
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="0"
                  >

                  <a
                    href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0"
                    class="farm-cart__remove"
                  >
                    Remove
                  </a>
                </div>

              </div>

            </article>

          {% endfor %}

        </div>

        <aside class="farm-cart__summary">

          <h2>Order Summary</h2>

          <div class="farm-cart__summary-row">
            <span>Subtotal</span>
            <strong>{{ cart.items_subtotal_price | money }}</strong>
          </div>

          <div class="farm-cart__summary-row">
            <span>Shipping</span>
            <strong>TBD</strong>
          </div>

          <div class="farm-cart__summary-row farm-cart__summary-row--total">
            <span>Estimated Total</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>

          <div class="farm-cart__notice">
            <p>
              <strong>Shipping note:</strong> Shipping is not included for gift boxes
              unless calculated after review. If shipping is selected, the Farm Store
              will contact the customer with the final shipping total.
            </p>

            <p>
              <strong>Pickup note:</strong> Gift baskets and pickup-only items must be
              collected from the CPP Farm Store.
            </p>

            <p>
              <strong>Important:</strong> We do not ship to PO Boxes.
            </p>
          </div>

          <div class="farm-cart__note">
            <label for="cart-note">
              Additional Order Notes
            </label>

            <textarea
              id="cart-note"
              name="note"
              rows="5"
              placeholder="Add any final notes for the Farm Store team."
            >{{ cart.note }}</textarea>
          </div>

          <div class="farm-cart__actions">
            <button type="submit" name="update" class="farm-cart__update">
              Update Cart
            </button>

            <button type="submit" name="checkout" class="farm-cart__checkout">
              Place Order
            </button>
          </div>

          <a href="/collections/all" class="farm-cart__continue">
            Continue Shopping
          </a>

        </aside>

      </div>

    </form>

  {% else %}

    <div class="farm-cart__empty">
      <h2>Your cart is empty.</h2>

      <p>
        Add a gift basket, gift box, fruit box, or Farm Store product to begin your order.
      </p>

      <a href="/collections/all" class="farm-cart__checkout">
        Browse Products
      </a>
    </div>

  {% endif %}
</section>

{% schema %}
{
  "name": "Farm Custom Cart",
  "settings": [],
  "presets": [
    {
      "name": "Farm Custom Cart"
    }
  ]
}
{% endschema %}