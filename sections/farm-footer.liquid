<footer class="farm-footer">
  <div class="farm-footer__inner">

    <div class="farm-footer__brand">
      <h2>CPP Farm Store</h2>

      <p>
        Fresh produce, local goods, campus-made products, and seasonal Farm Store
        favorites rooted in Cal Poly Pomona agriculture.
      </p>

      <a href="/collections/featured-products" class="farm-footer__button">
        Shop Products
      </a>
    </div>

    <div class="farm-footer__column">
      <h3>Visit Us</h3>

      <p>
        Farm Store at Kellogg Ranch<br>
        4102 S University Dr<br>
        Pomona, CA 91768
      </p>

      <p>
        <strong>Hours:</strong><br>
        Open daily, 10 a.m. – 6 p.m.
      </p>

      <div class="farm-footer__contact">
        <h4>Contact Information</h4>

        <p>
          <strong>Phone:</strong>
          <a href="tel:+19098694906">(909) 869-4906</a>
        </p>

        <p>
          <strong>Website:</strong>
          <a href="https://www.cpp.edu/farmstore/" target="_blank" rel="noopener">
            CPP Farm Store
          </a>
        </p>

        <p>
          <strong>Pickup note:</strong><br>
          Customers should wait for pickup confirmation before visiting for online orders.
        </p>
      </div>

      <div class="farm-footer__map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6306.027585722013!2d-117.819167!3d34.0484376!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c32c02ca822cb7%3A0x53b8abb081d53f8f!2sCal%20Poly%20Pomona%20Farm%20Store!5e1!3m2!1sen!2sus!4v1783393338650!5m2!1sen!2sus"
          width="100%"
          height="180"
          style="border: 0; border-radius: 8px; margin-top: 12px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
          title="CPP Farm Store location map">
        </iframe>
      </div>
    </div>

    <div class="farm-footer__column">
      <h3>Quick Links</h3>

      {% if section.settings.menu != blank %}
        <ul>
          {% for link in section.settings.menu.links %}
            <li>
              <a href="{{ link.url }}">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <ul>
          <li><a href="/collections/featured-products">Shop All Products</a></li>
          <li><a href="/collections/fresh-produce">Fresh Produce</a></li>
          <li><a href="/collections/gifts">Gift Baskets</a></li>
          <li><a href="/collections/cpp-favorites">CPP Favorites</a></li>
          <li><a href="/collections/student-snacks-drinks">Student Snacks & Drinks</a></li>
          <li><a href="/pages/visit-pickup-gift-order-faq">Visit & Pickup FAQ</a></li>
          <li><a href="/pages/our-story">Our Story</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      {% endif %}
    </div>

    <div class="farm-footer__column">
      <h3>Stay Connected</h3>

      <p>
        Follow along for seasonal product drops, campus-grown favorites,
        store announcements, and loyalty updates.
      </p>

      <div class="farm-footer__socials">
        <a href="https://www.instagram.com/thefarmstorecpp" target="_blank" rel="noopener">
          Instagram
        </a>

        <a href="https://www.facebook.com/CalPolyPomonaFarmstore/" target="_blank" rel="noopener">
          Facebook
        </a>
      </div>

      {% if section.settings.show_payment_icons %}
        <div class="farm-footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      {% endif %}
    </div>

  </div>

  <div class="farm-footer__bottom">
    <p>
      © {{ 'now' | date: '%Y' }}
      {{ shop.name }}.
      Built as a Shopify prototype for the CPP Farm Store consulting project.
    </p>

    <p class="farm-footer__powered">
      {{ powered_by_link }}
    </p>
  </div>
</footer>

{% schema %}
{
  "name": "Farm Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Farm Footer"
    }
  ]
}
{% endschema %}