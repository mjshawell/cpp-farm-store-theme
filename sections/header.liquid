<header class="site-header">
  <button
    class="menu-toggle"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-drawer"
    onclick="farmMenuOpen()"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <h2 class="header__title">
    {{ shop.name | link_to: routes.root_url }}
  </h2>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay" onclick="farmMenuClose()"></div>

<nav class="nav-drawer" id="nav-drawer" aria-label="Main navigation">
  <div class="nav-drawer__top">
    <span class="nav-drawer__brand">{{ shop.name }}</span>
    <button class="nav-drawer__close" aria-label="Close menu" onclick="farmMenuClose()">&times;</button>
  </div>

  <ul class="nav-drawer__list">
    {% for link in section.settings.menu.links %}
      <li>
        <a href="{{ link.url }}" {% if link.active %}class="is-active"{% endif %}>{{ link.title }}</a>
      </li>
    {% endfor %}
  </ul>
</nav>

<script>
  function farmMenuOpen() {
    document.getElementById('nav-drawer').classList.add('is-open');
    document.getElementById('nav-overlay').classList.add('is-open');
    document.querySelector('.menu-toggle').setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function farmMenuClose() {
    document.getElementById('nav-drawer').classList.remove('is-open');
    document.getElementById('nav-overlay').classList.remove('is-open');
    document.querySelector('.menu-toggle').setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') farmMenuClose();
  });
</script>

{% stylesheet %}
  .site-header {
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .site-header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .site-header a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
  }
  .site-header svg {
    width: 2rem;
  }
  .site-header .header__icons {
    display: flex;
    gap: 1rem;
  }

  /* Hamburger button */
  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 8px;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .menu-toggle span {
    display: block;
    height: 3px;
    width: 100%;
    background: #23351f;
    border-radius: 2px;
  }

  /* Overlay */
  .nav-overlay {
    position: fixed;
    inset: 0;
    background: rgba(31, 45, 31, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease;
    z-index: 90;
  }
  .nav-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  /* Drawer */
  .nav-drawer {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: min(320px, 85vw);
    background: #23351f;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    z-index: 100;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
  }
  .nav-drawer.is-open {
    transform: translateX(0);
  }
  .nav-drawer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .nav-drawer__brand {
    color: #f5c542;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .nav-drawer__close {
    background: transparent;
    border: none;
    color: #f8f4ec;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
  }
  .nav-drawer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .nav-drawer__list a {
    display: block;
    padding: 0.85rem 0.75rem;
    color: #f8f4ec;
    text-decoration: none;
    font-size: 1.05rem;
    border-radius: 6px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-drawer__list a:hover,
  .nav-drawer__list a.is-active {
    background: rgba(245, 197, 66, 0.15);
    color: #f5c542;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
