<header class="site-header" id="site-header">
  <button
    class="menu-toggle"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-drawer"
    onclick="farmMenuOpen()"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <h2 class="header__title">
    {{ shop.name | link_to: routes.root_url }}
  </h2>

  <div class="header__icons">
    <button
      class="search-toggle"
      aria-label="Open search"
      aria-expanded="false"
      aria-controls="search-panel"
      onclick="farmSearchOpen()"
    >
      {{ 'icon-search.svg' | inline_asset_content }}
    </button>

    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay" onclick="farmMenuClose()"></div>

<nav class="nav-drawer" id="nav-drawer" aria-label="Main navigation">
  <div class="nav-drawer__top">
    <span class="nav-drawer__brand">{{ shop.name }}</span>
    <button class="nav-drawer__close" aria-label="Close menu" onclick="farmMenuClose()">&times;</button>
  </div>

  <ul class="nav-drawer__list">
    {% for link in section.settings.menu.links %}
      <li>
        <a href="{{ link.url }}" {% if link.active %}class="is-active"{% endif %}>{{ link.title }}</a>
      </li>
    {% endfor %}
  </ul>
</nav>

<div class="search-overlay" id="search-overlay" onclick="farmSearchClose()"></div>

<div class="search-panel" id="search-panel" aria-label="Search products">
  <div class="search-panel__top">
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-panel__form" id="search-form">
      <input type="hidden" name="type" value="product">
      <input
        type="search"
        name="q"
        id="search-input"
        class="search-panel__input"
        placeholder="Search products..."
        autocomplete="off"
        aria-label="Search products"
      >
      <button type="submit" class="search-panel__submit" aria-label="Submit search">
        {{ 'icon-search.svg' | inline_asset_content }}
      </button>
    </form>
    <button class="search-panel__close" aria-label="Close search" onclick="farmSearchClose()">&times;</button>
  </div>

  <div class="search-panel__results" id="search-results"></div>
</div>

<script>
  function farmMenuOpen() {
    document.getElementById('nav-drawer').classList.add('is-open');
    document.getElementById('nav-overlay').classList.add('is-open');
    document.querySelector('.menu-toggle').setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function farmMenuClose() {
    document.getElementById('nav-drawer').classList.remove('is-open');
    document.getElementById('nav-overlay').classList.remove('is-open');
    document.querySelector('.menu-toggle').setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      farmMenuClose();
      farmSearchClose();
    }
  });

  /* ---- Search panel open/close ---- */
  function farmSearchOpen() {
    document.getElementById('search-panel').classList.add('is-open');
    document.getElementById('search-overlay').classList.add('is-open');
    document.querySelector('.search-toggle').setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    setTimeout(function () {
      document.getElementById('search-input').focus();
    }, 100);
  }
  function farmSearchClose() {
    document.getElementById('search-panel').classList.remove('is-open');
    document.getElementById('search-overlay').classList.remove('is-open');
    document.querySelector('.search-toggle').setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    document.getElementById('search-results').innerHTML = '';
    document.getElementById('search-input').value = '';
  }

  /* ---- Live predictive search using Shopify's suggest API ---- */
  (function () {
    var input = document.getElementById('search-input');
    var resultsBox = document.getElementById('search-results');
    var debounceTimer;

    if (!input) return;

    input.addEventListener('input', function () {
      var query = input.value.trim();
      clearTimeout(debounceTimer);

      if (query.length < 2) {
        resultsBox.innerHTML = '';
        return;
      }

      debounceTimer = setTimeout(function () {
        fetch('/search/suggest.json?q=' + encodeURIComponent(query) + '&resources[type]=product&resources[limit]=6&resources[options][unavailable_products]=last')
          .then(function (res) { return res.json(); })
          .then(function (data) {
            var products = (data.resources && data.resources.results && data.resources.results.products) || [];
            renderResults(products, query);
          })
          .catch(function () {
            resultsBox.innerHTML = '';
          });
      }, 250);
    });

    function renderResults(products, query) {
      if (!products.length) {
        resultsBox.innerHTML = '<p class="search-panel__empty">No products found for "' + escapeHtml(query) + '"</p>';
        return;
      }

      var html = '<ul class="search-panel__list">';
      products.forEach(function (product) {
        html += '<li class="search-panel__item">' +
          '<a href="' + product.url + '">' +
            (product.image ? '<img src="' + product.image + '" alt="' + escapeHtml(product.title) + '" width="50" height="50">' : '') +
            '<span class="search-panel__item-title">' + escapeHtml(product.title) + '</span>' +
            '<span class="search-panel__item-price">' + product.price + '</span>' +
          '</a>' +
        '</li>';
      });
      html += '</ul>';
      resultsBox.innerHTML = html;
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }
  })();

  /* ---- Sticky header: hide on scroll down, reveal on scroll up ---- */
  (function () {
    var header = document.getElementById('site-header');
    if (!header) return;

    var lastScrollY = window.scrollY;
    var ticking = false;

    var revealThreshold = 5;
    var hideAfter = header.offsetHeight;

    function onScroll() {
      var currentScrollY = window.scrollY;

      if (currentScrollY <= hideAfter) {
        header.classList.remove('site-header--hidden');
      } else if (currentScrollY > lastScrollY + 1) {
        header.classList.add('site-header--hidden');
      } else if (currentScrollY < lastScrollY - revealThreshold) {
        header.classList.remove('site-header--hidden');
      }

      lastScrollY = currentScrollY;
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

{% stylesheet %}
  .site-header {
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;

    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 80;
    background: var(--color-background, #fff);
    transform: translateY(0);
    transition: transform 0.25s ease;
  }
  .site-header--hidden {
    transform: translateY(-100%);
  }

  body {
    padding-top: 5rem;
  }

  .site-header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .site-header a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
  }
  .site-header svg {
    width: 2rem;
  }

  /* Icon row: even spacing across all three icons */
  .site-header .header__icons {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .search-toggle {
    background: transparent;
    border: none;
    padding: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .search-toggle svg {
    width: 1.75rem;
  }

  /* Hamburger button */
  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 8px;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .menu-toggle span {
    display: block;
    height: 3px;
    width: 100%;
    background: #23351f;
    border-radius: 2px;
  }

  /* Overlay (shared visual style, separate elements for menu vs search) */
  .nav-overlay,
  .search-overlay {
    position: fixed;
    inset: 0;
    background: rgba(31, 45, 31, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease;
    z-index: 90;
  }
  .nav-overlay.is-open,
  .search-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  /* Drawer */
  .nav-drawer {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: min(320px, 85vw);
    background: #23351f;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    z-index: 100;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
  }
  .nav-drawer.is-open {
    transform: translateX(0);
  }
  .nav-drawer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .nav-drawer__brand {
    color: #f5c542;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .nav-drawer__close {
    background: transparent;
    border: none;
    color: #f8f4ec;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
  }
  .nav-drawer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .nav-drawer__list a {
    display: block;
    padding: 0.85rem 0.75rem;
    color: #f8f4ec;
    text-decoration: none;
    font-size: 1.05rem;
    border-radius: 6px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-drawer__list a:hover,
  .nav-drawer__list a.is-active {
    background: rgba(245, 197, 66, 0.15);
    color: #f5c542;
  }

  /* Search panel */
  .search-panel {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: #fff;
    transform: translateY(-100%);
    transition: transform 0.25s ease;
    z-index: 100;
    padding: 1.5rem;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }
  .search-panel.is-open {
    transform: translateY(0);
  }
  .search-panel__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .search-panel__form {
    flex: 1;
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 0.25rem 0.5rem;
  }
  .search-panel__input {
    flex: 1;
    border: none;
    outline: none;
    padding: 0.6rem 0.5rem;
    font-size: 1rem;
    background: transparent;
  }
  .search-panel__submit {
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    padding: 0.4rem;
  }
  .search-panel__submit svg {
    width: 1.4rem;
  }
  .search-panel__close {
    background: transparent;
    border: none;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
  }
  .search-panel__results {
    margin-top: 1rem;
  }
  .search-panel__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .search-panel__item a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem;
    text-decoration: none;
    color: inherit;
    border-radius: 6px;
    transition: background 0.15s ease;
  }
  .search-panel__item a:hover {
    background: #f5f5f5;
  }
  .search-panel__item img {
    border-radius: 4px;
    object-fit: cover;
  }
  .search-panel__item-title {
    flex: 1;
    font-size: 0.95rem;
  }
  .search-panel__item-price {
    font-size: 0.9rem;
    color: #666;
  }
  .search-panel__empty {
    color: #666;
    font-size: 0.95rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}