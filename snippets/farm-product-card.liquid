<article class="farm-product-card">

  <a href="{{ product.url }}" class="farm-product-card__image-wrap" aria-label="View {{ product.title | escape }}">
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 700 }}"
        alt="{% if product.featured_image.alt != blank %}{{ product.featured_image.alt | escape }}{% else %}{{ product.title | escape }}{% endif %}"
        loading="lazy"
        class="farm-product-card__image"
      >
    {% else %}
      <div class="farm-product-card__placeholder">
        🧺
      </div>
    {% endif %}

    <div class="farm-product-card__badges">

      {% if product.available == false %}
        <span class="farm-product-card__badge farm-product-card__badge--pickup-only">
          Sold Out
        </span>
      {% endif %}

      {% if product.tags contains 'pickup-available' %}
        <span class="farm-product-card__badge">
          Pickup Available
        </span>
      {% endif %}

      {% if product.tags contains 'seasonal' %}
        <span class="farm-product-card__badge farm-product-card__badge--seasonal">
          Seasonal
        </span>
      {% endif %}

      {% if product.tags contains 'gift-box' or product.tags contains 'gift-basket' %}
        <span class="farm-product-card__badge farm-product-card__badge--gift">
          Gift Item
        </span>
      {% endif %}

      {% if product.tags contains 'pickup-only' %}
        <span class="farm-product-card__badge farm-product-card__badge--pickup-only">
          Pickup Only
        </span>
      {% endif %}

    </div>
  </a>

  <div class="farm-product-card__content">

    {% if product.type != blank %}
      <p class="farm-product-card__type">
        {{ product.type }}
      </p>
    {% endif %}

    <h3>
      <a href="{{ product.url }}">
        {{ product.title }}
      </a>
    </h3>

    <p class="farm-product-card__price">
      {% if product.price_varies %}
        From {{ product.price_min | money }}
      {% else %}
        {{ product.price | money }}
      {% endif %}
    </p>

    <p class="farm-product-card__note">
      {% if product.available == false %}
        Currently unavailable.
      {% elsif product.tags contains 'gift-box' or product.tags contains 'gift-basket' %}
        Requires 1–2 business days for preparation.
      {% elsif product.tags contains 'pickup-only' %}
        Available for local pickup only.
      {% elsif product.tags contains 'pickup-available' %}
        Available for Farm Store pickup.
      {% elsif product.tags contains 'seasonal' %}
        Seasonal availability may vary.
      {% else %}
        Browse product details and availability.
      {% endif %}
    </p>

    <div class="farm-product-card__actions">

      {% if product.available == false %}
        <a href="{{ product.url }}" class="farm-product-card__button">
          View Details
        </a>

      {% elsif product.tags contains 'gift-box' or product.tags contains 'gift-basket' %}
        <a href="{{ product.url }}" class="farm-product-card__button">
          Customize Gift
        </a>

      {% elsif product.variants.size == 1 %}
        <form method="post" action="{{ routes.cart_add_url }}">
          <input
            type="hidden"
            name="id"
            value="{{ product.selected_or_first_available_variant.id }}"
          >

          <input
            type="hidden"
            name="quantity"
            value="1"
          >

          <button type="submit" class="farm-product-card__button">
            Quick Add
          </button>
        </form>

      {% else %}
        <a href="{{ product.url }}" class="farm-product-card__button">
          View Product
        </a>
      {% endif %}

    </div>

  </div>

</article>